SECRET_KEY=replace-with-your-secret-key
DJANGO_DEBUG=False
CRM_ALLOW_ANY=False
ALLOWED_HOSTS=127.0.0.1,localhost
FRONTEND_URL=http://127.0.0.1:5173
STATIC_ROOT=staticfiles

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_USE_SSL=0
EMAIL_HOST_USER=replace-with-email-username
EMAIL_HOST_PASSWORD=replace-with-email-password
DEFAULT_FROM_EMAIL=replace-with-from-email
EMAIL_TIMEOUT=20

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_REDIRECT_URI=

EMAIL_OAUTH_SUCCESS_REDIRECT=http://localhost:5173/settings
EMAIL_OAUTH_ERROR_REDIRECT=http://localhost:5173/settings

EMAIL_TOKEN_ENCRYPTION_KEY=

DB_ENGINE=postgres
DB_NAME=legaledge_crm
DB_USER=replace-with-db-user
DB_PASSWORD=replace-with-db-password
DB_HOST=127.0.0.1
DB_PORT=5432
DB_SSLMODE=prefer
DB_CONN_MAX_AGE=0
